        </visual>
      </link>
    </model>

    <!-- East gap frame — crumbled pieces near the opening -->
    <model name="gap_rubble_n">
      <static>true</static>
      <pose>10 2.2 0.30 0.15 0.10 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.6 0.4 0.6</size></box></geometry></collision>
