<?xml version="1.0"?>
<robot name="group30Bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    group30Bot - Main URDF xacro file
    
    Robot: Differential drive two-wheeled robot with laser scanner
    Based on com760Bot.urdf
    Refactored to xacro as required by W8 Practical, W6/W7 Lectures
    
    Loads 3 supporting files:
    - macros.xacro: inertia calculation macros
    - materials.xacro: colour/material definitions  
    - group30Bot.gazebo: Gazebo plugins and physics properties
  -->

  <!-- Load supporting xacro files -->
  <xacro:include filename="$(find com760cw2_group30)/urdf/macros.xacro"/>
  <xacro:include filename="$(find com760cw2_group30)/urdf/materials.xacro"/>
  <xacro:include filename="$(find com760cw2_group30)/urdf/group30Bot.gazebo"/>

  <!-- 
    Dummy root link - required by KDL
    KDL does not support inertia on the root link
    This empty link acts as the true root, base_link_chassis connects to it
    Source: ROS REP-0105, Github
  -->
  <link name="base_link"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_link_chassis"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint> 

  <!-- Robot Chasis -->
  <!--
    Base link - the main body of the robot
    Box shape: 0.5m long, 0.3m wide, 0.07m tall
    Source: Provided file
  -->
  <link name="base_link_chassis">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.5 0.3 0.07"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.5 0.3 0.07"/>
      </geometry>
    </collision>
    <!-- Using macro instead of hardcoded numbers, source: macros.xacro -->
    <xacro:box_inertia m="5" w="0.3" h="0.07" d="0.5"/>
  </link>

  <!-- Caster Wheel -->
  <!--
    Passive front caster wheel for stability
    Sphere shape, low friction so it rotates freely in any direction
    Source: Provided file
  -->
  <link name="caster_link">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia m="0.1" r="0.05"/>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link_chassis"/>
    <child link="caster_link"/>
    <origin xyz="0.2 0 -0.05"/>
  </joint>

  <!-- Right Wheel -->
  <!--
    Continuous joint so can rotate freely (no limits)
    Axis xyz="0 1 0" means it rotates around the Y axis
    Source: Provided file, W6 Lecture
  -->
  <link name="right_wheel">
    <visual>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.1"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.2" r="0.1" h="0.04"/>
  </link>

  <joint name="right_wheel_hinge" type="continuous">
    <origin rpy="0 0 0" xyz="-0.05 0.15 0"/>
    <child link="right_wheel"/>
    <parent link="base_link_chassis"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <limit effort="10000" velocity="1000"/>
    <joint_properties damping="1.0" friction="1.0"/>
  </joint>

  <!-- Left Wheel -->
  <link name="left_wheel">
    <visual>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.1"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.2" r="0.1" h="0.04"/>
  </link>

  <joint name="left_wheel_hinge" type="continuous">
    <origin rpy="0 0 0" xyz="-0.05 -0.15 0"/>
    <child link="left_wheel"/>
    <parent link="base_link_chassis"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <limit effort="10000" velocity="1000"/>
    <joint_properties damping="1.0" friction="1.0"/>
  </joint>

  <!-- Laser Sensor -->
  <!--
    W8 Practical
    Cylinder shape representing a Hokuyo style laser scanner
    Mounted on top-front of chassis
    
    Inertia calculated using cylinder formula:
    Ixx = Iyy = (1/12)m(3r² + h²), Izz = (1/2)mr²
    Source: Wiki List of moments oinertia
    W8 Lecture
  -->
  <link name="laser_sensor">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.05"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.05"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.1" r="0.05" h="0.04"/>
  </link>

  <!--
    Fixed joint - laser doesn't move relative to chassis
    Positioned at front centre, slightly above chassis surface
    Source: W8 Lecture -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link_chassis"/>
    <child link="laser_sensor"/>
    <origin xyz="0.15 0 0.05" rpy="0 0 0"/>
  </joint>

</robot>
