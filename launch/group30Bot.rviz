Panels:
  - Class: rviz/Displays
    Name: Displays
Visualization Manager:
  Displays:
    - Class: rviz/RobotModel
      Name: RobotModel
      Enabled: true
    - Class: rviz/LaserScan
      Name: LaserScan
      Enabled: true
      Topic: /group30Bot/laser/scan
      Size (m): 0.05
      Color: 255; 0; 0
    - Class: rviz/TF
      Name: TF
      Enabled: false
  Global Options:
    Fixed Frame: odom
  Value: true
