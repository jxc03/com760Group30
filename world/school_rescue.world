<?xml version="1.0"?>
<sdf version="1.6">
  <world name="school_rescue_world">

    <physics type="ode">
      <real_time_update_rate>1000.0</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
    </physics>

    <scene>
      <ambient>0.6 0.55 0.50 1</ambient>
      <background>0.55 0.58 0.62 1</background>
      <shadows>true</shadows>
    </scene>

    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <!-- ============================================================
         OUTER WALLS  — beige brick, 22 x 10 m collapsed school.
         Robot spawns at (-8, 0).
         East wall has a 4 m gap (y=-2 to y=2) so the robot can
         exit to the emergency base at (11, 0).
         ============================================================ -->

    <!-- North wall — intact -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 5 1.2 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>22 0.35 2.4</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>22 0.35 2.4</size></box></geometry>
          <material><ambient>0.80 0.70 0.55 1</ambient><diffuse>0.80 0.70 0.55 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- North wall collapsed section (fallen outward, lying flat near y=5) -->
    <model name="wall_north_fallen">
      <static>true</static>
      <pose>-1 5.8 0.12 1.5708 0 0.10</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>4.0 0.35 2.4</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>4.0 0.35 2.4</size></box></geometry>
          <material><ambient>0.75 0.65 0.50 1</ambient><diffuse>0.75 0.65 0.50 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- South wall — intact -->
    <model name="wall_south">
      <static>true</static>
      <pose>0 -5 1.2 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>22 0.35 2.4</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>22 0.35 2.4</size></box></geometry>
          <material><ambient>0.80 0.70 0.55 1</ambient><diffuse>0.80 0.70 0.55 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- West wall — intact -->
    <model name="wall_west">
      <static>true</static>
      <pose>-10 0 1.2 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.35 10 2.4</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.35 10 2.4</size></box></geometry>
          <material><ambient>0.80 0.70 0.55 1</ambient><diffuse>0.80 0.70 0.55 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- East wall — north piece (y=2 to y=5), leaves exit gap -->
    <model name="wall_east_north">
      <static>true</static>
      <pose>10 3.5 1.2 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.35 3 2.4</size></box></geometry></collision>
        <visual name="vis">
